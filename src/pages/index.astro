---
import ListPrices from "@/components/react/ListPrices/ListPrices";
import LineChartPrices from "@/components/react/charts/LineChartPrices/LineChartPrices";
import CardResumen from "@/components/react/CardResumen/CardResumen";
import LeyendaPrecios from "@/components/react/LeyendaPrecios/LeyendaPrecios";
import PremiumHeader from "@/components/react/PremiumHeader/PremiumHeader";
import Footer from "@/components/react/Footer/Footer";
import type { Value } from "@/models/api.model";
import apiService from "@/services/api.service.ts";
import { transformToTwoDigits } from "@/utils/utils";
import "@/styles/global.css";

const url = Astro.url;
const dateParam = url.searchParams.get("date");
const tariffParam = url.searchParams.get("tariff") || "8741";

const selectedDate = dateParam ? new Date(dateParam + "T12:00:00") : new Date();
const dateStr = `${selectedDate.getFullYear()}-${transformToTwoDigits(selectedDate.getMonth() + 1)}-${transformToTwoDigits(selectedDate.getDate())}`;

let listPrices: Value[] = [];
try {
	listPrices = await apiService.getElectricityPricesDayAPI(selectedDate, tariffParam);
} catch (error: any) {
	console.error(error.message);
}
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Precio Horas Luz</title>
	</head>
	<body>
		<PremiumHeader client:load dateStr={dateStr} tariff={tariffParam} />

		<div class="page-wrapper">
			<div class="desktop-grid">
				<aside class="left-col">
					<CardResumen client:load prices={listPrices} />
					<LineChartPrices client:only prices={listPrices} />
					<LeyendaPrecios client:load />
				</aside>
				<main class="right-col">
					<ListPrices client:load prices={listPrices} />
				</main>
			</div>
		</div>

		<Footer client:load />

		<style>
			.page-wrapper {
				max-width: 1280px;
				margin: 0 auto;
				padding: 20px 20px 40px;
			}

			.desktop-grid {
				display: flex;
				flex-direction: column;
				gap: 16px;
			}

			.left-col,
			.right-col {
				display: flex;
				flex-direction: column;
				gap: 16px;
			}

			@media (min-width: 900px) {
				.desktop-grid {
					display: grid;
					grid-template-columns: 380px 1fr;
					gap: 20px;
					align-items: start;
				}

				.left-col {
					position: sticky;
					top: 20px;
				}
			}

			@media (min-width: 1100px) {
				.desktop-grid {
					grid-template-columns: 420px 1fr;
				}
			}
		</style>
	</body>
</html>
