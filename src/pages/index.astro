---
import ListPrices from "@/components/react/ListPrices/ListPrices";
import LineChartPrices from "@/components/react/charts/LineChartPrices/LineChartPrices";
import CardResumen from "@/components/react/CardResumen/CardResumen";
import LeyendaPrecios from "@/components/react/LeyendaPrecios/LeyendaPrecios";
import PremiumHeader from "@/components/react/PremiumHeader/PremiumHeader";
import type { Value } from "@/models/api.model";
import apiService from "@/services/api.service.ts";
import "@/styles/global.css";

let listPrices: Value[] = [];
try {
	listPrices = await apiService.getElectricityPricesDayAPI();
} catch (error: any) {
	console.error(error.message);
}

const today = new Date();
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Precio Horas Luz</title>
	</head>
	<body>
		<!-- Header full-width -->
		<PremiumHeader client:load date={today} />

		<!-- Contenido con layout desktop -->
		<div class="page-wrapper">
			<div class="desktop-grid">
				<!-- Columna izquierda: resumen rápido + gráfica -->
				<aside class="left-col">
					<CardResumen client:load prices={listPrices} />
					<LineChartPrices client:only prices={listPrices} />
					<LeyendaPrecios client:load />
				</aside>

				<!-- Columna derecha: listas de precios -->
				<main class="right-col">
					<ListPrices client:load prices={listPrices} />
				</main>
			</div>
		</div>

		<style>
			.page-wrapper {
				max-width: 1280px;
				margin: 0 auto;
				padding: 24px 24px 64px;
			}

			.desktop-grid {
				display: flex;
				flex-direction: column;
				gap: 20px;
			}

			.left-col,
			.right-col {
				display: flex;
				flex-direction: column;
				gap: 20px;
			}

			/* Desktop layout: 2 columnas */
			@media (min-width: 900px) {
				.desktop-grid {
					display: grid;
					grid-template-columns: 380px 1fr;
					gap: 24px;
					align-items: start;
				}

				.left-col {
					position: sticky;
					top: 24px;
				}
			}

			@media (min-width: 1100px) {
				.desktop-grid {
					grid-template-columns: 420px 1fr;
				}
			}
		</style>
	</body>
</html>
